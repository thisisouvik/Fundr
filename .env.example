# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Admin panel access (only this email can open /admin routes)
ADMIN_PANEL_EMAIL=admin@yourdomain.com

# Stellar / Soroban
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Admin / deployer wallet
# Public key  : admin-wallet-key
# ⚠️  The SECRET key below is server-only — never expose it client-side
STELLAR_FACTORY_SECRET_KEY=your_factory_account_secret_key

# Contract addresses — populated automatically by scripts/stellar/deploy.ps1
NEXT_PUBLIC_FACTORY_CONTRACT_ID=
NEXT_PUBLIC_CAMPAIGN_CONTRACT_ID=
